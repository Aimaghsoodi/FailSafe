{
  "name": "@failsafe/mcp-server",
  "version": "0.1.0",
  "description": "FailSafe MCP server — expose failure tracking to AI agents",
  "main": "dist/index.js",
  "bin": {
    "failsafe-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --sourcemap",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "failsafe",
    "failure",
    "risk",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "dependencies": {
    "@failsafe/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.50.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
