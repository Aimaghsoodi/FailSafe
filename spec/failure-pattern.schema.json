{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://failsafe.io/schema/failure-pattern.schema.json",
  "title": "FailSafe Failure Pattern",
  "description": "Schema for detected failure patterns and trends",
  "type": "object",
  "required": [
    "patternId",
    "name",
    "category",
    "frequency",
    "affectedFailures"
  ],
  "properties": {
    "patternId": {
      "type": "string",
      "pattern": "^pattern_[a-zA-Z0-9_-]{8,}$",
      "description": "Unique pattern identifier"
    },
    "name": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200,
      "description": "Pattern name"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Detailed pattern description"
    },
    "category": {
      "type": "string",
      "enum": [
        "legal",
        "medical",
        "financial",
        "coding",
        "factual",
        "reasoning",
        "temporal",
        "cross_domain"
      ]
    },
    "frequency": {
      "type": "object",
      "description": "Pattern occurrence frequency",
      "required": [
        "count",
        "period"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "period": {
          "type": "string",
          "enum": [
            "day",
            "week",
            "month",
            "quarter",
            "year"
          ]
        },
        "trend": {
          "type": "string",
          "enum": [
            "increasing",
            "stable",
            "decreasing"
          ]
        }
      }
    },
    "affectedFailures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^fail_[a-zA-Z0-9_-]{8,}$"
      },
      "description": "IDs of failures matching this pattern"
    },
    "commonRootCauses": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Root causes common across pattern failures"
    },
    "severity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Typical severity for this pattern"
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "description": "Overall risk of continued pattern occurrence"
    },
    "remediationStrategy": {
      "type": "string",
      "maxLength": 2000,
      "description": "Recommended remediation approach"
    },
    "preventionMeasures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Preventive measures to avoid future occurrences"
    },
    "detectedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When pattern was first detected"
    },
    "lastOccurrence": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of most recent failure in pattern"
    },
    "systemsAffected": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Systems or components affected by pattern"
    },
    "metadata": {
      "type": "object"
    }
  }
}
